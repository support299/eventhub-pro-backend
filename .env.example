# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (optional — SQLite is used by default in settings.py)
DB_NAME=eventhub
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS — comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080

# GoHighLevel
GHL_PRIVATE_TOKEN=
GHL_LOCATION_ID=
# Set to false locally to test webhooks with curl (production should verify signatures)
GHL_WEBHOOK_VERIFY=false

# Shared secret for magic-link auto-login — must match VITE_AUTO_LOGIN_SECRET in the frontend
AUTO_LOGIN_SECRET=change-me-to-a-random-secret
